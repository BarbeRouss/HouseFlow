@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Navigation

<div class="min-h-screen bg-background text-foreground">
    <header class="sticky top-0 z-10 flex h-14 items-center justify-between border-b bg-card px-4">
        <span class="text-lg font-semibold">🏠 HouseFlow</span>
        <AuthorizeView>
            <Authorized>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-muted-foreground">@context.User.Identity?.Name</span>
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="@LogoutAsync">
                        Déconnexion
                    </BbButton>
                </div>
            </Authorized>
        </AuthorizeView>
    </header>

    <main class="p-4">
        @Body
    </main>
</div>

@* Required for overlays (toasts, dialogs, popovers). *@
<BbPortalHost />
<BbToastProvider Position="ToastPosition.BottomRight" />

@code {
    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Navigation.NavigateTo("login");
    }
}
