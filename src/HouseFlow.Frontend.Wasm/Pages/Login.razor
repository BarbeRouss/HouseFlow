@page "/login"
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Connexion — HouseFlow</PageTitle>

<div class="flex justify-center mt-12">
    <BbCard Class="w-full max-w-md">
        <BbCardHeader>
            <BbCardTitle>Connexion</BbCardTitle>
            <BbCardDescription>Accédez à votre espace HouseFlow.</BbCardDescription>
        </BbCardHeader>

        <EditForm Model="_model" OnValidSubmit="OnSubmit">
            <BbCardContent class="space-y-4">
                <div class="space-y-2">
                    <BbLabel For="email">Email</BbLabel>
                    <BbInput Id="email" Type="InputType.Email" @bind-Value="_model.Email"
                             Placeholder="vous@exemple.com" AriaLabel="Email"
                             Required="true" Class="w-full" />
                </div>

                <div class="space-y-2">
                    <BbLabel For="password">Mot de passe</BbLabel>
                    <BbInput Id="password" Type="InputType.Password" @bind-Value="_model.Password"
                             AriaLabel="Mot de passe" Required="true" Class="w-full" />
                </div>

                @if (_error is not null)
                {
                    <BbAlert Variant="AlertVariant.Danger">
                        <BbAlertDescription>@_error</BbAlertDescription>
                    </BbAlert>
                }
            </BbCardContent>

            <BbCardFooter>
                <BbButton Type="ButtonType.Submit" Variant="ButtonVariant.Default"
                          Loading="@_busy" LoadingText="Connexion…" Class="w-full">
                    Se connecter
                </BbButton>
            </BbCardFooter>
        </EditForm>
    </BbCard>
</div>

@code {
    private readonly LoginModel _model = new();
    private string? _error;
    private bool _busy;

    private async Task OnSubmit()
    {
        if (string.IsNullOrWhiteSpace(_model.Email) || string.IsNullOrWhiteSpace(_model.Password))
        {
            _error = "Email et mot de passe requis.";
            return;
        }

        _busy = true;
        _error = null;

        _error = await Auth.LoginAsync(_model.Email, _model.Password);

        _busy = false;

        if (_error is null)
        {
            var returnUrl = GetReturnUrl();
            Navigation.NavigateTo(string.IsNullOrEmpty(returnUrl) ? "houses" : returnUrl);
        }
    }

    private string? GetReturnUrl()
    {
        var query = Navigation.ToAbsoluteUri(Navigation.Uri).Query.TrimStart('?');
        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = pair.Split('=', 2);
            if (kv.Length == 2 && kv[0] == "returnUrl")
                return Uri.UnescapeDataString(kv[1]);
        }
        return null;
    }

    private sealed class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
