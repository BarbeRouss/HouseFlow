@page "/houses"
@attribute [Authorize]
@inject HousesService HousesApi

<PageTitle>Mes maisons — HouseFlow</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">Mes maisons</h1>
        @if (_data is not null)
        {
            <BbBadge Variant="BadgeVariant.Default">Score global : @_data.GlobalScore%</BbBadge>
        }
    </div>

    @if (_loading)
    {
        <BbSpinner Size="SpinnerSize.Large" />
    }
    else if (_error is not null)
    {
        <BbAlert Variant="AlertVariant.Danger">
            <BbAlertDescription>@_error</BbAlertDescription>
        </BbAlert>
    }
    else if (_data is { Houses.Count: 0 })
    {
        <p class="text-muted-foreground">Aucune maison pour le moment.</p>
    }
    else if (_data is not null)
    {
        <BbDataTable TData="HouseSummary" Data="@_data.Houses" ShowPagination="true" InitialPageSize="10">
            <Columns>
                <BbDataTableColumn TData="HouseSummary" TValue="string" Property="@(x => x.Name)" Header="Nom" Sortable="true" />
                <BbDataTableColumn TData="HouseSummary" TValue="string" Property="@(x => x.City ?? "")" Header="Ville" Sortable="true" />
                <BbDataTableColumn TData="HouseSummary" TValue="int" Property="@(x => x.DevicesCount)" Header="Appareils" Sortable="true" />
                <BbDataTableColumn TData="HouseSummary" TValue="int" Property="@(x => x.OverdueCount)" Header="En retard" Sortable="true">
                    <CellTemplate Context="house">
                        <BbBadge Variant="@(house.OverdueCount > 0 ? BadgeVariant.Destructive : BadgeVariant.Secondary)">
                            @house.OverdueCount
                        </BbBadge>
                    </CellTemplate>
                </BbDataTableColumn>
                <BbDataTableColumn TData="HouseSummary" TValue="int" Property="@(x => x.Score)" Header="Score" Sortable="true" Width="180px">
                    <CellTemplate Context="house">
                        <div class="flex items-center gap-2">
                            <BbProgress Value="@house.Score" Max="100" Class="w-28" />
                            <span class="text-sm tabular-nums">@house.Score%</span>
                        </div>
                    </CellTemplate>
                </BbDataTableColumn>
            </Columns>
        </BbDataTable>
    }
</div>

@code {
    private HousesListResponse? _data;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _data = await HousesApi.GetHousesAsync();
        }
        catch (HttpRequestException)
        {
            _error = "Impossible de charger les maisons.";
        }
        finally
        {
            _loading = false;
        }
    }
}
