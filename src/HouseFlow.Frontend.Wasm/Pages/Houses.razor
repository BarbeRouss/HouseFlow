@page "/houses"
@attribute [Authorize]
@inject HousesService HousesApi

<PageTitle>Mes maisons — HouseFlow</PageTitle>

<RadzenStack Gap="1.5rem">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween">
        <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-m-0">Mes maisons</RadzenText>
        @if (_data is not null)
        {
            <RadzenBadge BadgeStyle="BadgeStyle.Primary" Text="@($"Score global : {_data.GlobalScore}%")" />
        }
    </RadzenStack>

    @if (_loading)
    {
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else if (_error is not null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" ShowIcon="true" AllowClose="false">
            @_error
        </RadzenAlert>
    }
    else if (_data is { Houses.Count: 0 })
    {
        <RadzenText>Aucune maison pour le moment.</RadzenText>
    }
    else if (_data is not null)
    {
        <RadzenDataGrid TItem="HouseSummary" Data="@_data.Houses" AllowSorting="true" AllowFiltering="false"
                        AllowPaging="true" PageSize="10" class="rz-shadow-2">
            <Columns>
                <RadzenDataGridColumn TItem="HouseSummary" Property="Name" Title="Nom" />
                <RadzenDataGridColumn TItem="HouseSummary" Property="City" Title="Ville" />
                <RadzenDataGridColumn TItem="HouseSummary" Property="DevicesCount" Title="Appareils" TextAlign="TextAlign.Center" />
                <RadzenDataGridColumn TItem="HouseSummary" Property="OverdueCount" Title="En retard" TextAlign="TextAlign.Center">
                    <Template Context="house">
                        <RadzenBadge BadgeStyle="@(house.OverdueCount > 0 ? BadgeStyle.Danger : BadgeStyle.Light)"
                                     Text="@house.OverdueCount.ToString()" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="HouseSummary" Property="Score" Title="Score" Width="160px">
                    <Template Context="house">
                        <RadzenProgressBar Value="@house.Score" ShowValue="true" Unit="%"
                                           Mode="ProgressBarMode.Determinate" Style="width:100%" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</RadzenStack>

@code {
    private HousesListResponse? _data;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _data = await HousesApi.GetHousesAsync();
        }
        catch (HttpRequestException)
        {
            _error = "Impossible de charger les maisons.";
        }
        finally
        {
            _loading = false;
        }
    }
}
